{\n  "manifest_version": 3,\n  "name": "Tawasol Monitor",\n  "version": "1.0",\n  "description": "Firefox extension for monitoring Tawasol at 172.23.16.230",\n  "permissions": [\n    "storage",\n    "notifications"\n  ],\n  "background": {\n    "service_worker": "background.js"\n  },\n  "action": {\n    "default_popup": "popup.html",\n    "default_icon": {\n      "16": "images/icon16.png",\n      "48": "images/icon48.png",\n      "128": "images/icon128.png"\n    }\n  },\n  "icons": {\n    "16": "images/icon16.png",\n    "48": "images/icon48.png",\n    "128": "images/icon128.png"\n  },\n  "options_page": "options.html",\n  "content_scripts": [\n    {\n      "matches": ["http://172.23.16.230/*", "https://172.23.16.230/*"],\n      "js": ["content.js"]\n    }\n  ],\n  "web_accessible_resources": [\n    {\n      "resources": ["images/*"],\n      "matches": ["http://172.23.16.230/*", "https://172.23.16.230/*"]\n    }\n  ]\n}